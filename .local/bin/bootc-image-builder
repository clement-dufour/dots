#!/usr/bin/env bash

set -euo pipefail
# set -x

container_image="${1}"
shift

truncate disk.raw --size 4G

sudo podman run \
    --rm \
    -it \
    --pull=newer \
    --privileged \
    --security-opt label=type:unconfined_t \
    --pid=host \
    --volume ./disk.raw:/disk.raw \
    "${container_image}" \
    bootc install to-disk \
    --enforce-container-sigpolicy \
    --generic-image \
    --via-loopback '/disk.raw' \
    "${@}"
